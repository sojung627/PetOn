<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.db.dao.PetDao">

<!-- pet_insert_form.jsp - 동물 등록 -->
<insert id="insert" parameterType="pet">
   INSERT INTO pet (
    pet_idx,
    mem_idx,
    pet_name,
    pet_species,
    pet_gender,
    pet_breed,
    pet_age,
    pet_bday,
    is_primary
) VALUES (
    nextval('seq_pet_idx'),
    #{mem_idx},
    #{pet_name},
    #{pet_species},
    #{pet_gender},
    #{pet_breed},
    #{pet_age},
    #{pet_bday},
    #{is_primary}
)
</insert>


<!-- petProfile.jsp - 유저의 반려동물 조회 -->
<select id="selectByMemIdx" parameterType="int" resultType="pet">
    SELECT * FROM pet
    WHERE mem_idx = #{mem_idx}
    ORDER BY is_primary DESC, pet_idx ASC
</select>

  
<!-- 펫 1마리 조회 -->
<select id="selectOneByPetIdx"
        parameterType="int"
        resultType="pet">
    SELECT * FROM pet
    WHERE pet_idx = #{pet_idx}
</select>


<!-- petUpdate.jsp - 펫 정보 수정 -->
<!-- 1. 기존 대표동물 전부 N 처리 -->
<update id="resetPrimaryByMemIdx" parameterType="int">
    UPDATE pet
    SET is_primary = 'N'
    WHERE mem_idx = #{mem_idx}
</update>

<!-- 2. 선택한 펫을 Y 처리 -->
<update id="setPrimaryByPetIdx" parameterType="int">
    UPDATE pet
    SET is_primary = 'Y'
    WHERE pet_idx = #{pet_idx}
</update>

<update id="update" parameterType="pet">
    UPDATE pet SET
        pet_name = #{pet_name},
        pet_species = #{pet_species},
        pet_gender = #{pet_gender},
        pet_breed = #{pet_breed},
        pet_age = #{pet_age},
        pet_bday = #{pet_bday},
        is_primary = #{is_primary}
    WHERE pet_idx = #{pet_idx}
</update>

