<!-- 대표동물만 조회하기 -->
<select id="selectPrimaryPet" parameterType="int" resultType="pet">
    SELECT * FROM pet 
    WHERE mem_idx = #{mem_idx} AND is_primary = 'Y' 
    ORDER BY pet_idx DESC 
    FETCH FIRST 1 ROW ONLY
</select>


